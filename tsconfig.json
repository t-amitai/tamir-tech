{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "baseUrl": "./client/src",
    "allowJs": true
  },
  "include": ["client/src/**/*.ts", "client/src/**/*.tsx"],
  "exclude": ["node_modules", "client/dist"]
}
